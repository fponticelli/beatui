{
  "name": "@beatui/docs",
  "version": "1.0.0",
  "type": "module",
  "description": "BeatUI Documentation Site",
  "scripts": {
    "dev": "pnpm gen:api && vite",
    "build": "pnpm gen:api:force && vite build",
    "preview": "vite preview",
    "gen:api": "tsx scripts/generate-api-json.ts",
    "gen:api:force": "tsx scripts/generate-api-json.ts --force",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:all": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke --project=chromium",
    "test:e2e:a11y": "playwright test --grep @a11y --project=chromium",
    "test:e2e:visual": "playwright test --grep @visual --project=chromium",
    "test:e2e:component": "playwright test --grep @component --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update-snapshots": "playwright test --update-snapshots --project=chromium"
  },
  "keywords": [
    "documentation",
    "beatui",
    "vite"
  ],
  "author": "Franco Ponticelli",
  "license": "MIT",
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "@tempots/beatui": "workspace:*",
    "@tempots/dom": "^37.5.0",
    "@tempots/std": "~0.29.1",
    "@tempots/ui": "^16.1.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "25.2.3",
    "tailwindcss": "4.1.18",
    "tsx": "4.21.0",
    "typedoc": "^0.28.18",
    "typescript": "5.9.3",
    "vite": "7.3.1"
  },
  "packageManager": "pnpm@10.21.0"
}
